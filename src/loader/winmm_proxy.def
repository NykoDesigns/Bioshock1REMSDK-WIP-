    waveOutWrite             = proxy_waveOutWrite
    waveOutPause             = proxy_waveOutPause
    waveOutRestart           = proxy_waveOutRestart
    waveOutReset             = proxy_waveOutReset
    waveOutGetPosition       = proxy_waveOutGetPosition
    waveOutMessage           = proxy_waveOutMessage
    waveInGetNumDevs         = proxy_waveInGetNumDevs
